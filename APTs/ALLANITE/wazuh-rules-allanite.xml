<group name="sysmon,allanite_hunting,">
  <!-- رول شناسایی جستجوی مشکوک اطلاعات و پسوردها با ابزارهای بومی سیستم‌عامل -->
  <rule id="100801" level="11">
    <if_sid>61603</if_sid> <!-- Sysmon Event ID 1 -->
    <field name="win.eventdata.commandLine" type="pcre2">(?i)findstr.*(pass|password|pwd|config)</field>
    <!-- حذف نویز ناشی از اسکریپت‌های مجاز سیستم‌عامل و مانیتورینگ سازمان برای جلوگیری از آلارم کاذب -->
    <field name="win.eventdata.parentImage" condition="not_contains">userinit.exe</field>
    <field name="win.eventdata.parentImage" condition="not_contains">PRTG Probe.exe</field>
    <description>⚠️ Alert: Reconnaissance and File Discovery for Sensitive Data detected (Potential ALLANITE Activity)!</description>
    <mitre>
      <id>T1083</id>
    </mitre>
  </rule>
</group>
