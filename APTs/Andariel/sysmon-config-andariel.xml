<Sysmon schemaversion="4.50">
  <EventFiltering>
    <!-- Event ID 8: CreateRemoteThread - Hunting Remote Code Injection into Command Interpreters -->
    <RuleGroup name="andariel_memory_injection_hunting" groupRelation="or">
      <CreateRemoteThread onmatch="include">
        <!-- شکار تلاش برای تزریق کد مخرب به ابزارهای خط فرمان و پاورشل سیستم -->
        <TargetImage condition="end with">cmd.exe</TargetImage>
        <TargetImage condition="end with">powershell.exe</TargetImage>
      </CreateRemoteThread>
    </RuleGroup>

    <!-- 🛑 بخش فیلتر هشدارهای کاذب (False Positive Exclusions) -->
    <RuleGroup name="andariel_fp_exclusions" groupRelation="or">
      <CreateRemoteThread onmatch="exclude">
        <!-- استثنا کردن فرآیندهای امضاشده و کامپوننت‌های بومی خود ویندوز -->
        <SourceImage condition="is">C:\Windows\System32\csrss.exe</SourceImage>
        <!-- استثنا کردن ارتباطات مجاز از سمت ابزار پراب مانیتورینگ دپارتمان IT سازمان -->
        <SourceImage condition="is">C:\Program Files (x86)\PRTG Network Monitor\PRTG Probe.exe</SourceImage>
      </CreateRemoteThread>
    </RuleGroup>
  </EventFiltering>
</Sysmon>
